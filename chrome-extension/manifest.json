{
  "manifest_version": 3,
  "name": "Aviaparser Direct Monitor",
  "version": "1.1.0",
  "description": "Собирает цены с сайтов авиакомпаний через обычный Chrome и отправляет их в Aviaparser.",
  "permissions": ["alarms", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Aviaparser Direct Monitor"
  },
  "content_scripts": [
    {
      "matches": ["https://www.aeroflot.ru/*/sb/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://ibe.s7.ru/*"],
      "js": ["content-s7.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
